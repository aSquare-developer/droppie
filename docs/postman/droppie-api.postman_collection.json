    "name": "droppie API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the droppie API. Covers health, email-based auth lifecycle, profile, routes, refresh flow, and PDF generation."
