    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/profile"
          }
        },
        {
          "name": "Upsert Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carOwner\": \"aSquare OU\",\n  \"carModel\": \"Toyota Corolla\",\n  \"carRegnumber\": \"981RFD\",\n  \"vehicleUser\": \"Artur Anissimov\"\n}"
            },
            "url": "{{baseUrl}}/api/users/profile"
          }
        }
      ]
    },
    {
      "name": "Routes",
      "item": [
        {
          "name": "List Routes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/routes?page=1&per=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "routes"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Create Route",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('baseUrl') + '/api/users/routes?page=1&per=1',",
                  "  method: 'GET',",
                  "  header: { Authorization: 'Bearer ' + pm.collectionVariables.get('accessToken') }",
                  "}, function (err, res) {",
                  "  if (err) { return; }",
                  "  const body = res.json();",
                  "  if (body.items && body.items.length > 0) {",
                  "    pm.collectionVariables.set('routeId', body.items[0].id);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": \"Tallinn\",\n  \"destination\": \"Tartu\",\n  \"date\": \"2026-04-20T09:00:00Z\"\n}"
            },
            "url": "{{baseUrl}}/api/users/route"
          }
        },
        {
          "name": "Delete Route",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/route/{{routeId}}"
          }
        },
        {
          "name": "Generate Routes PDF",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/routes/generate?month=4&year=2026&currentOdometer=276743.0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "routes",
                "generate"
              ],
              "query": [
                {
                  "key": "month",
                  "value": "4"
                },
                {
                  "key": "year",
                  "value": "2026"
                },
                {
                  "key": "currentOdometer",
                  "value": "276743.0"
                }
              ]
            }
          }
        }
      ]
    }
