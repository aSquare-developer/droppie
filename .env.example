JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_LIFETIME_SECONDS=86400
AUTO_MIGRATE=false
ENABLE_HSTS=true
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_BLOCK_DURATION_SECONDS=900

# Comma-separated list of allowed browser origins. Leave empty to disable CORS.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Database: use either DATABASE_URL or the DB_* variables below.
# DATABASE_URL=postgres://username:password@hostname:5432/database
DB_HOST_NAME=127.0.0.1
DB_USER_NAME=droppie
DB_PASSWORD=change-me
DB_NAME=droppie
DB_TLS=false

# Optional integrations
# REDIS_URL=redis://127.0.0.1:6379
# GOOGLE_ROUTES_API_KEY=replace-with-google-routes-api-key
# WKHTMLTOPDF_PATH=/usr/local/bin/wkhtmltopdf
